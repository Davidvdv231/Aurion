# =============================================================================
# Aurion — Environment Configuration
# Copy this file to .env and fill in values for your environment.
# =============================================================================

# -- Application --------------------------------------------------------------
APP_ENV=development                          # development | staging | production

# -- Server / CORS ------------------------------------------------------------
CORS_ALLOW_ORIGINS=http://localhost:8000,http://127.0.0.1:8000
# Comma-separated list of allowed origins. Never use "*" in production.

# -- AI Provider --------------------------------------------------------------
OPENAI_API_KEY=                              # Required for AI-powered predictions
OPENAI_CHAT_COMPLETIONS_URL=https://api.openai.com/v1/chat/completions
OPENAI_MODEL=gpt-4o-mini

# Alternative / self-hosted LLM
STOCK_LLM_API_URL=
STOCK_LLM_API_KEY=

# -- Redis (required in production) -------------------------------------------
REDIS_URL=                                   # e.g. redis://localhost:6379/0
REDIS_PREFIX=stock-predictor
REDIS_SOCKET_TIMEOUT_SECONDS=1.0

# -- Caching ------------------------------------------------------------------
TOP_CACHE_TTL_SECONDS=900                    # 15 minutes
HISTORY_CACHE_TTL_SECONDS=300                # 5 minutes
MEMORY_CACHE_MAX_ITEMS=512
MEMORY_CACHE_SWEEP_BATCH_SIZE=64

# -- Executor / Timeouts ------------------------------------------------------
EXECUTOR_MAX_WORKERS=8
BLOCKING_TASK_TIMEOUT_SECONDS=15.0
TOP_ASSETS_TIMEOUT_SECONDS=8.0

# -- Rate Limiting -------------------------------------------------------------
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_MAX_REQUESTS_STAT=30
RATE_LIMIT_MAX_REQUESTS_AI=8
RATE_LIMIT_MAX_REQUESTS_SEARCH=60
RATE_LIMIT_FAIL_OPEN=true                    # Set to false in production

# -- ML Quality Gates ----------------------------------------------------------
ML_MIN_VALIDATION_WINDOWS=3
ML_MIN_DIRECTIONAL_ACCURACY=0.45
ML_MAX_MAPE_VS_BASELINE=1.0

# -- Security ------------------------------------------------------------------
TRUSTED_PROXY_IPS=                           # Comma-separated, e.g. 10.0.0.0/8

# -- Artifacts -----------------------------------------------------------------
ARTIFACTS_ROOT=./artifacts
