# OpenAI
OPENAI_API_KEY=HIER_JE_OPENAI_KEY
OPENAI_MODEL=gpt-4o-mini

# Optional custom AI endpoint
STOCK_LLM_API_URL=
STOCK_LLM_API_KEY=

# Optional shared cache / rate limiting
REDIS_URL=
REDIS_PREFIX=stock-predictor
APP_ENV=development

# Optional app config
CORS_ALLOW_ORIGINS=http://127.0.0.1:8000,http://localhost:8000
BLOCKING_TASK_TIMEOUT_SECONDS=15
TOP_ASSETS_TIMEOUT_SECONDS=8
EXECUTOR_MAX_WORKERS=8
MEMORY_CACHE_MAX_ITEMS=512
MEMORY_CACHE_SWEEP_BATCH_SIZE=64
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_MAX_REQUESTS_STAT=30
RATE_LIMIT_MAX_REQUESTS_AI=8
RATE_LIMIT_MAX_REQUESTS_SEARCH=60
# Development defaults to true; production remains fail-closed if Redis is unavailable.
RATE_LIMIT_FAIL_OPEN=true
TRUSTED_PROXY_IPS=

# ML forecasting runtime
ARTIFACTS_ROOT=artifacts
ML_NEIGHBOR_COUNT=24
ML_BACKTEST_WINDOWS=24
ML_MIN_HISTORY_ROWS=180
